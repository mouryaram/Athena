# Copy this to .env and fill in your values

# ─── Data Providers ──────────────────────────────────────────────────────────
MARKET_DATA_PROVIDER=yfinance       # yfinance | polygon
POLYGON_API_KEY=your_polygon_key_here
ALPHA_VANTAGE_KEY=your_av_key_here

QUANT_PROVIDER=mock                 # mock | unusual_whales | tradier
UNUSUAL_WHALES_KEY=your_uw_key_here
TRADIER_KEY=your_tradier_key_here

# ─── Telegram Alerts ─────────────────────────────────────────────────────────
ALERTS_ENABLED=false
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_CHAT_ID=your_chat_id_here

# ─── Strategy ────────────────────────────────────────────────────────────────
CONFIDENCE_THRESHOLD=80
MAX_RISK_PCT=1.0
MIN_RR=2.0

# ─── Server ──────────────────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8000
LOG_LEVEL=INFO
